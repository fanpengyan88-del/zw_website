{
  "name": "zw-corporate-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "start:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-lan-server.ps1",
    "build": "prisma generate && next build",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-standalone.ps1 && node .next/standalone/server.js",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@phosphor-icons/react": "^2.1.7",
    "@prisma/client": "^6.7.0",
    "next": "^15.3.2",
    "prisma": "^6.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "playwright": "^1.60.0",
    "postcss": "^8.5.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
